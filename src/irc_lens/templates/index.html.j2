<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>irc-lens — {{ session.nick }}@{{ session.host }}</title>
    <link rel="icon" type="image/png" sizes="32x32" href="/static/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/static/favicon-16x16.png">
    <link rel="icon" href="/static/favicon.ico">
    <link rel="apple-touch-icon" href="/static/culture-logo.png">
    <meta name="color-scheme" content="dark">
    <link rel="stylesheet" href="/static/lens.css">
    <script src="/static/vendor/htmx.min.js" defer></script>
    <script src="/static/vendor/sse.js" defer></script>
    <script src="/static/lens.js" defer></script>
  </head>
  <body data-view="{{ session.view }}">
    <header class="lens-header">
      <img class="lens-logo" src="/static/culture-logo.png" alt="Culture" width="24" height="24">
      <span data-testid="connection-status" class="lens-conn {{ 'lens-conn--healthy' if session.healthy else 'lens-conn--down' }}">
        {% if session.healthy %}connected{% else %}disconnected{% endif %}
      </span>
      <span class="lens-identity">{{ session.nick }}@{{ session.host }}:{{ session.port }}</span>
    </header>

    <main class="lens-grid">
      <aside data-testid="sidebar" id="sidebar" class="lens-sidebar">
        {% include "_sidebar.html.j2" %}
      </aside>

      <section class="lens-chat">
        <div data-testid="chat-log" id="chat-log" class="lens-log">
          {# Initial page render: server-fetched HISTORY for current_channel
             arrives pre-rendered as `chat_log_html`. Live messages keep
             arriving via SSE `chat` events. Page reloads re-fetch fresh
             history from the IRCd's SQLite store. #}
          {{ chat_log_html|safe }}
        </div>
        <form id="chat-form" class="lens-form" hx-post="/input" hx-trigger="submit" hx-swap="none">
          <input
            data-testid="chat-input"
            id="chat-input"
            name="text"
            type="text"
            autocomplete="off"
            placeholder="Type a message or /command…">
          <button data-testid="chat-submit" id="chat-submit" type="submit">send</button>
        </form>
      </section>

      <aside data-testid="info" id="info" class="lens-info">
        {% include "_info.html.j2" %}
      </aside>
    </main>

    <div id="toast-region" aria-live="polite" aria-atomic="true"></div>
  </body>
</html>
